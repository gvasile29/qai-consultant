h2 {
 line-height: 1.1!important;
}

h1 {
 line-height: 1.1!important;
}

li.bullet-arrow{
	padding:20px 20px!important;
	border:0px!important;
}

p {
	line-height: 29px
}

li.bullet-checkmark:before, ul li.bullet-star:before {
    color: #004f86!important;
}

/*Menu Edits*/
div.flex-col.hide-for-medium.flex-right{
	width:800px;
}

